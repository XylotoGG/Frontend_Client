<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend_Client.Views.Client_SavedRaketeer"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F1F0EC">

    <Grid>

        <!-- Main Background -->
        <Border BackgroundColor="#F1F0EC"
                StrokeThickness="0">

            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Back -->
                <Grid Grid.Row="0"
                      Margin="16,20,0,10"
                      HorizontalOptions="Start">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Source="backbutton.svg"
                           WidthRequest="20"
                           HeightRequest="20"
                           VerticalOptions="Center"/>

                    <Label Grid.Column="1"
                           Text="Back"
                           Margin="6,0,0,0"
                           FontSize="16"
                           TextColor="Black"
                           VerticalOptions="Center"/>

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BackButton_Tapped"/>
                    </Grid.GestureRecognizers>

                </Grid>

                <!-- Title -->
                <Label Grid.Row="1"
                       Text="Saved Raketeers"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#134E43"
                       HorizontalOptions="Center"
                       Margin="0,0,0,16"/>

                <!-- List -->
                <CollectionView Grid.Row="2"
                                x:Name="SavedList"
                                Margin="16,0,16,16">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="14"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Border BackgroundColor="White"
                                    Stroke="#D8D8D8"
                                    StrokeThickness="1"
                                    Padding="16">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="50,*,Auto"
                                      ColumnSpacing="14">

                                    <!-- Avatar -->
                                    <Border WidthRequest="42"
                                            HeightRequest="42"
                                            BackgroundColor="#E9DEFF"
                                            StrokeThickness="0">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>

                                        <Label Text="{Binding Initials}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#6B5CA5"/>

                                    </Border>

                                    <!-- Name -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Spacing="2">

                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1F1F1F"/>

                                        <Label Text="{Binding Profession}"
                                               FontSize="12"
                                               TextColor="#777777"/>

                                    </VerticalStackLayout>

                                    <!-- Arrow -->
                                    <Image Grid.Column="2"
                                           Source="arrowright.svg"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           VerticalOptions="Center"/>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

                <!-- Bottom Navigation -->
                <Grid Grid.Row="3"
                      HeightRequest="60"
                      BackgroundColor="#0C4F3C"
                      ColumnDefinitions="*,*,*,*">

                    <!-- Home -->
                    <Grid Grid.Column="0"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">

                        <Image Source="home.svg"
                               WidthRequest="22"
                               HeightRequest="22"/>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Home_Tapped"/>
                        </Grid.GestureRecognizers>

                    </Grid>

                    <!-- Inbox -->
                    <Grid Grid.Column="1"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">

                        <Image Source="inbox.svg"
                               WidthRequest="22"
                               HeightRequest="22"/>

                        <Grid.GestureRecognizers>
                            <!-- <TapGestureRecognizer Tapped="Inbox_Tapped"/> -->
                        </Grid.GestureRecognizers>

                    </Grid>

                    <!-- Notifications -->
                    <Grid Grid.Column="2"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">

                        <Image Source="notifications.svg"
                               WidthRequest="22"
                               HeightRequest="22"/>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Notifications_Tapped"/>
                        </Grid.GestureRecognizers>

                    </Grid>

                    <!-- Settings -->
                    <Grid Grid.Column="3"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">

                        <Image Source="settings.svg"
                               WidthRequest="22"
                               HeightRequest="22"/>

                        <Grid.GestureRecognizers>
                            <!-- <TapGestureRecognizer Tapped="Settings_Tapped"/> -->
                        </Grid.GestureRecognizers>

                    </Grid>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</ContentPage>