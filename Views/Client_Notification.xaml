<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend_Client.Views.Client_Notification"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F1F0EC">

    <Grid RowDefinitions="Auto,*"
          Padding="0">

        <!-- Full white content panel -->
        <Border Grid.Row="1"
                BackgroundColor="#F1F0EC"
                Stroke="Transparent"
                Margin="0">

            <!-- Main Layout -->
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

                <!-- Back Button -->
                <Grid Grid.Row="0"
                      Margin="16,20,0,10"
                      HorizontalOptions="Start">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Source="backbutton.svg"
                           WidthRequest="20"
                           HeightRequest="20"
                           VerticalOptions="Center"/>

                    <Label Grid.Column="1"
                           Text="Back"
                           Margin="6,0,0,0"
                           FontSize="16"
                           TextColor="Black"
                           VerticalOptions="Center"/>

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BackButton_Tapped"/>
                    </Grid.GestureRecognizers>

                </Grid>

                <!-- Title -->
                <Label Grid.Row="1"
                       Text="Notifications"
                       FontAttributes="Bold"
                       FontSize="20"
                       TextColor="#1B4D3E"
                       HorizontalOptions="Center"
                       Margin="0,0,0,14"/>

                <!-- Tabs -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      Margin="16,0,16,14"
                      HeightRequest="42"
                      BackgroundColor="#E5E3DC"
                      Padding="3">

                    <Border Grid.Column="0"
                            x:Name="RaketRequestsTabBorder"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent">

                        <Label x:Name="RaketRequestsTabLabel"
                               Text="Raket Requests"
                               FontAttributes="Bold"
                               FontSize="13"
                               TextColor="#1F1F1F"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="RaketRequestsTab_Tapped"/>
                        </Border.GestureRecognizers>

                    </Border>

                    <Border Grid.Column="1"
                            x:Name="MessagesTabBorder"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent">

                        <Label x:Name="MessagesTabLabel"
                               Text="Messages"
                               FontSize="13"
                               TextColor="#8A8A8A"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="MessagesTab_Tapped"/>
                        </Border.GestureRecognizers>

                    </Border>

                </Grid>

                <!-- Notifications List -->
                <ScrollView Grid.Row="3"
                            Padding="16,0,16,10">

                    <CollectionView x:Name="NotificationsList">

                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <Border BackgroundColor="White"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 16"
                                        Padding="14,12">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="NotificationItem_Tapped"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12">

                                        <Border Grid.Column="0"
                                                WidthRequest="40"
                                                HeightRequest="40"
                                                BackgroundColor="#E9E4F7"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 20">

                                            <Label Text="{Binding Initials}"
                                                   FontAttributes="Bold"
                                                   FontSize="13"
                                                   TextColor="#6B5CA5"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>

                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="2">

                                            <Label Text="{Binding Name}"
                                                   FontAttributes="Bold"
                                                   FontSize="15"
                                                   TextColor="#1F1F1F"/>

                                            <Label Text="{Binding Message}"
                                                   FontSize="12"
                                                   TextColor="#8A8A8A"/>

                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Text=">"
                                               FontSize="16"
                                               TextColor="#8A8A8A"
                                               VerticalOptions="Center"/>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </ScrollView>

                <!-- BOTTOM NAVIGATION -->
                <Grid Grid.Row="4"
                      HeightRequest="60"
                      BackgroundColor="#1B4D3E"
                      ColumnDefinitions="*,*,*,*">

                    <!-- Home -->
                    <Grid Grid.Column="0"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="40"
                          HeightRequest="40">

                        <Image Source="home.svg"
                               WidthRequest="20"
                               HeightRequest="20"/>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Home_Tapped"/>
                        </Grid.GestureRecognizers>

                    </Grid>

                    <!-- Inbox -->
                    <Grid Grid.Column="1"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="40"
                          HeightRequest="40">

                        <Image Source="inbox.svg"
                               WidthRequest="24"
                               HeightRequest="24"/>

                        <Grid.GestureRecognizers>
                            <!-- <TapGestureRecognizer Tapped="Inbox_Tapped"/> -->
                        </Grid.GestureRecognizers>

                    </Grid>

                    <!-- Notifications -->
                    <Grid Grid.Column="2"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="40"
                          HeightRequest="40">

                        <Image Source="notifications.svg"
                               WidthRequest="24"
                               HeightRequest="24"/>

                        <Grid.GestureRecognizers>
                            <!-- <TapGestureRecognizer Tapped="Notifications_Tapped"/> -->
                        </Grid.GestureRecognizers>

                    </Grid>

                    <!-- Settings -->
                    <Grid Grid.Column="3"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="40"
                          HeightRequest="40">

                        <Image Source="settings.svg"
                               WidthRequest="20"
                               HeightRequest="20"/>

                        <Grid.GestureRecognizers>
                            <!-- <TapGestureRecognizer Tapped="Settings_Tapped"/> -->
                        </Grid.GestureRecognizers>

                    </Grid>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</ContentPage>